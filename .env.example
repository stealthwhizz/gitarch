# ============================================================================
# Git Archaeologist - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# .env is git-ignored for security - NEVER commit it to git
# ============================================================================

# ============================================================================
# LLM PROVIDER - Choose ONE of the options below
# ============================================================================

# OPTION 1: Anthropic Claude (RECOMMENDED)
# Get key from: https://console.anthropic.com/account/keys
# Requires paid credits (separate from Claude Pro subscription)
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OPTION 2: OpenAI GPT-4o
# Get key from: https://platform.openai.com/api-keys
# Requires separate API billing setup
# OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# OPTION 3: Mistral (FREE TIER AVAILABLE) ✅ RECOMMENDED FOR FREE
# Get key from: https://console.mistral.ai/
# Sign up free, includes free tier credits
# MISTRAL_API_KEY=YOUR_MISTRAL_KEY_HERE

# OPTION 4: Google Gemini (FREE TIER AVAILABLE)
# Get key from: https://aistudio.google.com/app/apikeys
# Free tier available
# GOOGLE_API_KEY=YOUR_GOOGLE_KEY_HERE

# OPTION 5: Groq (FREE TIER AVAILABLE)
# Get key from: https://console.groq.com/
# Extremely fast, free tier
# GROQ_API_KEY=YOUR_GROQ_KEY_HERE

# ============================================================================
# MODEL SELECTION
# ============================================================================
# Uncomment the line that matches your chosen provider above

# Anthropic
# GITAGENT_MODEL=anthropic:claude-sonnet-4-5-20250929

# OpenAI
# GITAGENT_MODEL=openai:gpt-4o

# Mistral (default)
# GITAGENT_MODEL=mistral:mistral-large-latest

# Google Gemini
# GITAGENT_MODEL=google:gemini-2.0-flash

# Groq
# GITAGENT_MODEL=groq:mixtral-8x7b-32768

# ============================================================================
# GITHUB TOKEN (OPTIONAL - for private repos)
# ============================================================================
# Get from: https://github.com/settings/tokens
# Scope: "repo" (full control of private repos)
# GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ============================================================================
# DEBUG MODE (OPTIONAL)
# ============================================================================
# Uncomment to see detailed investigation steps
# DEBUG=1

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. Choose an LLM provider (Mistral recommended for free):
#    - Go to the provider's website
#    - Sign up and create an API key
#    - Uncomment the corresponding API_KEY line below
#    - Paste your actual key
#
# 2. Uncomment the GITAGENT_MODEL line for your provider
#
# 3. Save this file as .env in the gitarch directory
#
# 4. Run investigations:
#    cd /path/to/opengap
#    node ../gitarch/index.js "Your question?" --dir ../gitarch
#
# ============================================================================


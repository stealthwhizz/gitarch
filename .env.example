# ============================================================================
# Git Archaeologist - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values.
# .env is git-ignored — NEVER commit it.
# ============================================================================

# ============================================================================
# LYZR (Required)
# ============================================================================
# Your Lyzr API key from https://studio.lyzr.ai
LYZR_API_KEY=your-lyzr-api-key-here

# The Lyzr agent ID to use as the model backend
GITAGENT_LYZR_AGENT_ID=your-lyzr-agent-id-here

# ============================================================================
# GITHUB TOKEN (Required for private repos, recommended for public)
# ============================================================================
# Generate at: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=your-github-personal-access-token

# ============================================================================
# OPTIONAL
# ============================================================================
# Override the full model string (advanced use)
# GITAGENT_MODEL=lyzr:your-agent-id@https://agent-prod.studio.lyzr.ai/v4

# Enable verbose debug output
# DEBUG=1
